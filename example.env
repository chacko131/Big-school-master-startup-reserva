# ==============================================================================
# ARCHIVO: .env.example
# RESPONSABILIDAD: Plantilla de configuración de variables de entorno para el entorno local.
# TIPO: Configuración del Sistema / Despliegue
# ==============================================================================
#
# INSTRUCCIONES DE USO:
# 1. Copia este archivo y renombralo a `.env` en la raíz del proyecto:
#    cp .env.example .env
# 2. Reemplaza los valores de marcador de posición por tus credenciales de desarrollo.
# 3. NUNCA subas el archivo `.env` con credenciales reales a tu repositorio de Git.
#
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DIRECCIONES URL DEL SISTEMA
# ------------------------------------------------------------------------------
# La URL base donde corre el servidor de Next.js en desarrollo local.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# La URL de retorno para el flujo del panel de administración (debe coincidir con la de desarrollo o producción).
NEXT_PUBLIC_HOST_NAME="http://localhost:3000/dashboard/"


# ------------------------------------------------------------------------------
# 2. BASE DE DATOS (PostgreSQL / Neon / Supabase)
# ------------------------------------------------------------------------------
# URL de conexión directa a la base de datos PostgreSQL compatible con Prisma.
# - Si utilizas Neon: Copia el connection string desde tu consola del proyecto (Transaction pooler recomendado).
# - Ejemplo formato local: "postgresql://usuario:contraseña@localhost:5432/reservalatina?schema=public"
DATABASE_URL="postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD?sslmode=require"


# ------------------------------------------------------------------------------
# 3. AUTENTICACIÓN (Clerk Auth)
# ------------------------------------------------------------------------------
# Obtén tus credenciales registrando una aplicación en el dashboard de Clerk (https://dashboard.clerk.com).
# Llave pública de Clerk para inicializar el SDK en el cliente.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_TU_CLERK_PUBLIC_KEY"

# Llave secreta de Clerk para operaciones seguras en el servidor Next.js.
CLERK_SECRET_KEY="sk_test_TU_CLERK_SECRET_KEY"

# Rutas internas de redirección de Clerk (rutas por defecto manejadas en el middleware):
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding/restaurant"


# ------------------------------------------------------------------------------
# 4. GESTIÓN DE CONTENIDOS Y MULTIMEDIA (Cloudinary)
# ------------------------------------------------------------------------------
# Utilizado para el almacenamiento de imágenes de la galería del restaurante y fotos de los menús.
# Consigue estos valores en tu consola de Cloudinary (https://cloudinary.com/console).
CLOUD_NAME="TU_CLOUD_NAME"
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"


# ------------------------------------------------------------------------------
# 5. PASARELA DE PAGOS Y SUSCRIPCIONES (Stripe Billing)
# ------------------------------------------------------------------------------
# Consigue tus claves en la sección de Desarrolladores de Stripe (https://dashboard.stripe.com/test/apikeys).
# Llave pública de Stripe para inicializar elementos de cobro en cliente (Stripe Elements / Checkout).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_TU_STRIPE_PUBLISHABLE_KEY"

# Llave secreta de Stripe para operaciones del servidor, creación de sesiones y portales de facturación.
STRIPE_SECRET_KEY="sk_test_TU_STRIPE_SECRET_KEY"

# Secreto de firma del Webhook para verificar la autenticidad de los eventos enviados por Stripe.
# - En desarrollo local: Se obtiene al iniciar el túnel de Stripe CLI (`stripe listen`).
# - En producción: Se obtiene al configurar el Webhook endpoint en el Dashboard de Stripe.
STRIPE_WEBHOOK_SECRET="whsec_TU_STRIPE_WEBHOOK_SECRET_PARA_PROBAR_LOCAL"

# IDs de los Planes/Precios de Suscripción creados en el catálogo de productos de tu cuenta de Stripe.
# - STRIPE_BASIC_PRICE_ID: ID de precio del plan Básico (ej. recurrente mensual, ej: price_1Q...).
# - STRIPE_PRO_PRICE_ID: ID de precio del plan Pro (ej. recurrente mensual, ej: price_1Q...).
STRIPE_BASIC_PRICE_ID="price_TU_ID_PLAN_BASICO"
STRIPE_PRO_PRICE_ID="price_TU_ID_PLAN_PRO"


# ------------------------------------------------------------------------------
# 6. SISTEMA DE NOTIFICACIONES MULTICANAL (Novu)
# ------------------------------------------------------------------------------
# Consigue tus claves y configura tus flujos en la consola de Novu (https://dashboard.novu.co o tu instancia self-hosted).
# Identificador de la aplicación (Application Identifier) para inicializar el componente de bandeja de notificaciones (Inbox).
NEXT_PUBLIC_NOVU_APPLICATION_IDENTIFIER="TU_NOVU_APPLICATION_IDENTIFIER"

# API Key de integración secreta para disparar workflows de notificaciones desde el backend de Next.js.
NOVU_API_KEY="TU_NOVU_API_KEY"

# URL base de la API backend de tu servidor de Novu (dejar por defecto para nube, o cambiar para self-hosted).
# Ejemplo self-hosted: "https://novu.tudominio.com/api"
NEXT_PUBLIC_NOVU_BACKEND_URL="https://api.novu.co/api"

# URL de conexión websocket para actualizaciones en vivo de notificaciones in-app.
# Ejemplo self-hosted: "wss://novu.tudominio.com"
NEXT_PUBLIC_NOVU_SOCKET_URL="wss://ws.novu.co"


# ------------------------------------------------------------------------------
# 7. PROVEEDOR DE EMAILS (Resend)
# ------------------------------------------------------------------------------
# Utilizado para el envío de correos transaccionales directos (ej. invitaciones de equipo).
# Regístrate y obtén tu API Key en Resend (https://resend.com).
RESEND_API_KEY="re_TU_RESEND_API_KEY"

# Dirección de correo electrónico verificada del remitente para correos enviados a clientes.
# - En desarrollo: Puedes usar "onboarding@resend.dev" para enviar a tu propia dirección verificada.
# - En producción: Debe ser una dirección de tu dominio verificado (ej. "hola@tudominio.com").
RESEND_FROM_EMAIL="Reserva Latina <noreply@tudominio.com>"
