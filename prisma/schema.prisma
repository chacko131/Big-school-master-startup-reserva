// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

/// Archivo: schema.prisma
/// Responsabilidad: Definir el modelo de datos de Reserva Latina para restaurantes, configuración operativa, mesas, huéspedes, reservas y catálogo público (horarios, fotos y carta).
/// Tipo: esquema de datos

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationApprovalMode {
  AUTO
  MANUAL
}

enum WaitlistMode {
  MANUAL
  AUTO
}

enum TableShape {
  SQUARE
  ROUND
  BAR
}

enum FloorPlanElementType {
  WALL
  PLANT
}

/// Rango de precio orientativo que verá el cliente en el perfil público del restaurante.
enum PriceRange {
  BUDGET      // $
  MODERATE    // $$
  UPSCALE     // $$$
  FINE_DINING // $$$$
}

/// Días de la semana para los horarios de apertura.
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Restaurant {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  timezone     String              @default("Europe/Madrid")
  isActive     Boolean             @default(true)
  version      Int                 @default(1)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  /// --- Datos de contacto ---
  phone        String?
  email        String?

  /// --- Perfil público (catálogo) — todos opcionales para no romper registros existentes ---
  description     String?   /// Descripción corta que verá el cliente en el perfil.
  address         String?   /// Calle y número (ej: "Calle Aristóteles 124").
  city            String?   /// Ciudad (ej: "Ciudad de México").
  countryCode     String?   /// ISO 3166-1 alpha-2 (ej: "MX", "ES").
  cuisine         String?   /// Tipo de cocina (ej: "Mexicana", "Italiana").
  priceRange      PriceRange?
  heroImage       Json?     /// Guardará un objeto { url, publicId }
  galleryImages   Json?     /// Guardará un array de objetos [{ url, publicId }, ...]

  /// --- Relaciones ---
  settings      RestaurantSettings?
  tables        DiningTable[]
  zones         RestaurantZone[]
  floorElements FloorPlanElement[]
  guests        Guest[]
  reservations  Reservation[]
  businessHours BusinessHours[]
  menuCategories MenuCategory[]
  memberships   UserRestaurantMembership[]

  @@index([isActive])
  @@index([slug])
}

model RestaurantSettings {
  id                                String                  @id @default(cuid())
  restaurantId                      String                  @unique
  reservationApprovalMode           ReservationApprovalMode @default(AUTO)
  waitlistMode                      WaitlistMode            @default(MANUAL)
  defaultReservationDurationMinutes Int                     @default(90)
  reservationBufferMinutes          Int                     @default(15)
  cancellationWindowHours           Int                     @default(24)
  allowTableCombination             Boolean                 @default(true)
  enableAutoTableAssignment         Boolean                 @default(true)
  version                           Int                     @default(1)
  createdAt                         DateTime                @default(now())
  updatedAt                         DateTime                @updatedAt
  restaurant                        Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model RestaurantZone {
  id           String       @id @default(cuid())
  restaurantId String
  name         String
  color        String       @default("#6366f1")
  sortOrder    Int          @default(0)
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       DiningTable[]
  floorElements FloorPlanElement[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model DiningTable {
  id               String             @id @default(cuid())
  restaurantId     String
  zoneId           String?
  name             String
  capacity         Int                @default(4)
  isActive         Boolean            @default(true)
  isCombinable     Boolean            @default(false)
  sortOrder        Int                @default(0)
  shape            TableShape         @default(SQUARE)
  x                Int?
  y                Int?
  width            Int?
  height           Int?
  version          Int                @default(1)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  zone             RestaurantZone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  reservationLinks ReservationTable[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
  @@index([restaurantId, zoneId])
}

model Guest {
  id           String        @id @default(cuid())
  restaurantId String
  fullName     String
  phone        String
  email        String?
  notes        String?
  noShowCount  Int           @default(0)
  version      Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([restaurantId, phone])
  @@index([restaurantId, fullName])
  @@index([restaurantId, email])
}

model Reservation {
  id                     String             @id @default(cuid())
  restaurantId           String
  guestId                String
  status                 ReservationStatus  @default(PENDING)
  partySize              Int
  startAt                DateTime
  endAt                  DateTime
  cancellationDeadlineAt DateTime?
  cancelledAt            DateTime?
  checkedInAt            DateTime?
  completedAt            DateTime?
  noShowMarkedAt         DateTime?
  specialRequests        String?
  internalNotes          String?
  version                Int                @default(1)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  restaurant             Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  guest                  Guest              @relation(fields: [guestId], references: [id], onDelete: Restrict)
  tableAssignments       ReservationTable[]

  @@index([restaurantId, status, startAt])
  @@index([restaurantId, startAt, endAt])
  @@index([restaurantId, guestId])
}

model ReservationTable {
  id            String      @id @default(cuid())
  reservationId String
  tableId       String
  assignedSeats Int?
  version       Int         @default(1)
  assignedAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table         DiningTable @relation(fields: [tableId], references: [id], onDelete: Restrict)

  @@unique([reservationId, tableId])
  @@index([tableId, assignedAt])
}

model FloorPlanElement {
  id           String               @id @default(cuid())
  restaurantId String
  zoneId       String?
  type         FloorPlanElementType
  x            Int
  y            Int
  width        Int
  height       Int
  rotation     Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  zone         RestaurantZone?      @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, zoneId])
}

/// Horarios de apertura del restaurante por día de la semana.
/// Un restaurante puede tener múltiples franjas por día (ej: comida y cena).
model BusinessHours {
  id           String     @id @default(cuid())
  restaurantId String
  day          DayOfWeek
  opensAt      String     /// Formato HH:mm (ej: "13:00")
  closesAt     String     /// Formato HH:mm (ej: "23:00")
  isClosed     Boolean    @default(false) /// true = el restaurante cierra ese día.
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, day])
}

/// Categoría de la carta (ej: Entrantes, Principales, Postres, Bebidas).
/// Permite ordenar los platos en el perfil público.
model MenuCategory {
  id           String       @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
}

/// Plato individual de la carta.
/// La carta es un módulo premium, pero el modelo se define ahora para no tener que migrar después.
model MenuItem {
  id             String       @id @default(cuid())
  categoryId     String
  name           String
  description    String?      /// Ingredientes, preparación o nota del chef.
  price          Decimal?     @db.Decimal(10, 2) /// null = precio a consultar (ej: mercado).
  imageUrl       String?      /// URL de Cloudinary. Opcional por plato.
  imagePublicId  String?      /// Public ID de Cloudinary para poder eliminar la imagen.
  allergens      String[]     /// Lista de alérgenos (ej: ["gluten", "lactosa"]). Array vacío por defecto.
  isAvailable    Boolean      @default(true)  /// false = plato de temporada o agotado.
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, isAvailable])
  @@index([categoryId, sortOrder])
}

// ---------------------------------------------------------------------------
// MÓDULO: USERS
// ---------------------------------------------------------------------------

/// Rol global del usuario dentro de la plataforma SaaS.
/// SUPER_ADMIN → dueño de la startup (acceso total a todos los restaurantes).
/// USER        → cualquier usuario autenticado sin privilegios globales.
enum GlobalRole {
  SUPER_ADMIN
  USER
}

/// Rol del usuario dentro de un restaurante concreto.
/// Un mismo usuario puede tener distintos roles en distintos restaurantes.
enum MembershipRole {
  RESTAURANT_OWNER  /// Dueño del restaurante. Puede invitar staff y gestionar todo.
  MANAGER           /// Gerente. Ve todo excepto billing.
  STAFF_WAITER      /// Mesero. Ve reservas y agenda.
  STAFF_KITCHEN     /// Cocina. Ve solo la agenda/timeline.
  STAFF_BAR         /// Barra. Ve reservas.
}

/// Estado del vínculo entre un usuario y un restaurante.
/// PENDING  → invitado pero aún no ha aceptado.
/// ACTIVE   → acceso activo y operativo.
/// REVOKED  → acceso revocado por el owner o el admin.
enum MembershipStatus {
  PENDING
  ACTIVE
  REVOKED
}

/// Usuario autenticado de la plataforma.
/// La identidad real la gestiona Clerk; aquí guardamos la representación de negocio.
/// clerkId es el "sub" que devuelve Clerk en cada sesión.
model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique /// Identificador único de Clerk (sub del JWT).
  email       String       @unique
  fullName    String?
  globalRole  GlobalRole   @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships           UserRestaurantMembership[] @relation("UserMemberships")
  sentInvitations       UserRestaurantMembership[] @relation("InvitedByUser")

  @@index([email])
  @@index([clerkId])
}

/// Vínculo entre un User y un Restaurant con un rol específico.
/// Un user puede pertenecer a varios restaurantes con roles distintos.
/// Un restaurante puede tener un único RESTAURANT_OWNER activo.
model UserRestaurantMembership {
  id           String           @id @default(cuid())
  userId       String
  restaurantId String
  role         MembershipRole
  status       MembershipStatus @default(PENDING)
  invitedById  String?          /// FK al User que generó la invitación. Null si es el owner original.
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User         @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([userId, restaurantId]) /// Un user solo puede tener un rol por restaurante.
  @@index([userId, status])
  @@index([restaurantId, role, status])
}
